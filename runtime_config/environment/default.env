# SANSKAR RUNTIME - DEFAULT ENVIRONMENT CONFIGURATION
# NO hardcoded local assumptions - all paths relative or environment-driven

# === RUNTIME IDENTITY ===
SANSKAR_PARTICIPANT_ID=sanskar-participant-1
SANSKAR_ROLE=intelligence-analyzer
SANSKAR_AUTHORITY_OWNER=engineering-team

# === TANTRA ECOSYSTEM CONFIGURATION ===
TANTRA_ENVIRONMENT=integration
TANTRA_REGISTRY_URL=http://registry.tantra.local:8080
TANTRA_TRACE_BACKEND=bucket-truth-layer

# === PORT CONFIGURATION (relative to deployment environment) ===
SANSKAR_PORT=8001
SANSKAR_HEALTH_PORT=8002
SANSKAR_METRICS_PORT=8003

# === SERVICE DISCOVERY ===
SERVICE_DISCOVERY_MODE=dns  
RAJYA_DISCOVERY_URL=${RAJYA_SERVICE_URL:-http://rajya:8080}
ENFORCEMENT_DISCOVERY_URL=${ENFORCEMENT_SERVICE_URL:-http://enforcement:8080}
BUCKET_DISCOVERY_URL=${BUCKET_SERVICE_URL:-http://bucket:8080}
INSIGHTBRIDGE_DISCOVERY_URL=${INSIGHTBRIDGE_SERVICE_URL:-http://insightbridge:8080}

# === STORAGE & PERSISTENCE ===
EVENT_STORE_URL=${EVENT_STORE_URL:-./event_store.db}
LINEAGE_PERSISTENCE_URL=${LINEAGE_PERSISTENCE_URL:-./lineage.json}
CACHE_MODE=in-memory  

# === TRACE & OBSERVABILITY ===
TRACE_EXPORT_BACKEND=otlp  

TRACE_BATCH_SIZE=100
TRACE_FLUSH_INTERVAL_MS=5000
LOG_LEVEL=INFO  

# === SECURITY & GOVERNANCE ===
GOVERNANCE_MODE=strict 
CONSTITUTIONAL_BOUNDARY_CHECK=enabled
REPLAY_VERIFICATION=enabled
SCHEMA_VALIDATION_STRICT=true

# === TIMEOUTS (milliseconds) ===
SERVICE_CALL_TIMEOUT_MS=30000
RAJYA_VALIDATION_TIMEOUT_MS=10000
ENFORCEMENT_ACK_TIMEOUT_MS=15000
BUCKET_PERSISTENCE_TIMEOUT_MS=5000

# === DEPLOYMENT RUNTIME FLAGS ===
ENABLE_DEBUG_ENDPOINTS=false
ENABLE_SIMULATION_MODE=false  
SINGLE_PROCESS_SIMULATION=false
ALLOW_LOCAL_ONLY=false  

# === HEALTH CHECK CONFIGURATION ===
HEALTH_CHECK_INTERVAL_MS=30000
READINESS_CHECK_DEPENDENCIES=rajya,enforcement,bucket
LIVENESS_CHECK_TIMEOUT_MS=5000

# === CONTRACT REGISTRY ===
CONTRACT_REGISTRY_PATH=./adapter_layer/contract_registry.json
SCHEMA_EVOLUTION_SUPPORT=true
SCHEMA_VERSIONS_SUPPORTED=v1,v1.1,v1.2

# === REPLAY CONFIGURATION ===
REPLAY_DETERMINISM_STRICT=true
REPLAY_TRACE_ID_IMMUTABLE=true
REPLAY_LINEAGE_PERSIST=true
REPLAY_DIVERGENCE_DETECTION=enabled

# === PERFORMANCE TUNING (environment-specific) ===
MAX_CONCURRENT_EXECUTIONS=100
QUEUE_MAX_SIZE=10000
BATCH_PROCESSING_ENABLED=true
BATCH_SIZE=50
