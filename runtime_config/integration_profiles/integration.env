

TANTRA_ENVIRONMENT=integration
SERVICE_DISCOVERY_MODE=dns
RAJYA_DISCOVERY_URL=http://rajya-service:8080
ENFORCEMENT_DISCOVERY_URL=http://enforcement-service:8080
BUCKET_DISCOVERY_URL=http://bucket-service:8080
INSIGHTBRIDGE_DISCOVERY_URL=http://insightbridge-service:8080

SANSKAR_PORT=8001
LOG_LEVEL=INFO
ENABLE_DEBUG_ENDPOINTS=false


ALLOW_LOCAL_ONLY=false


SERVICE_CALL_TIMEOUT_MS=30000
RAJYA_VALIDATION_TIMEOUT_MS=10000


EVENT_STORE_URL=http://storage-backend:5432/sanskar_events
LINEAGE_PERSISTENCE_URL=http://storage-backend:5432/sanskar_lineage


GOVERNANCE_MODE=strict
CONSTITUTIONAL_BOUNDARY_CHECK=enabled
REPLAY_VERIFICATION=enabled
SCHEMA_VALIDATION_STRICT=true


READINESS_CHECK_DEPENDENCIES=rajya,enforcement,bucket,insightbridge



TRACE_EXPORT_BACKEND=otlp
TRACE_BATCH_SIZE=100
