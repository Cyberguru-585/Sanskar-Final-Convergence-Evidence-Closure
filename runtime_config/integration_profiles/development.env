

TANTRA_ENVIRONMENT=development
SERVICE_DISCOVERY_MODE=static
RAJYA_DISCOVERY_URL=http://localhost:8010
ENFORCEMENT_DISCOVERY_URL=http://localhost:8011
BUCKET_DISCOVERY_URL=http://localhost:8012
INSIGHTBRIDGE_DISCOVERY_URL=http://localhost:8013

SANSKAR_PORT=8001
LOG_LEVEL=DEBUG
ENABLE_DEBUG_ENDPOINTS=true



ALLOW_LOCAL_ONLY=true

SERVICE_CALL_TIMEOUT_MS=60000


ENABLE_SIMULATION_MODE=false
SINGLE_PROCESS_SIMULATION=true


EVENT_STORE_URL=./data/event_store.db
LINEAGE_PERSISTENCE_URL=./data/lineage.json

GOVERNANCE_MODE=observability-only
CONSTITUTIONAL_BOUNDARY_CHECK=disabled
