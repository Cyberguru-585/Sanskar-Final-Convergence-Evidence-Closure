

TANTRA_ENVIRONMENT=staging
SERVICE_DISCOVERY_MODE=consul
RAJYA_DISCOVERY_URL=http://rajya-service.staging:8080
ENFORCEMENT_DISCOVERY_URL=http://enforcement-service.staging:8080
BUCKET_DISCOVERY_URL=http://bucket-service.staging:8080
INSIGHTBRIDGE_DISCOVERY_URL=http://insightbridge-service.staging:8080

SANSKAR_PORT=8001
LOG_LEVEL=WARN
ENABLE_DEBUG_ENDPOINTS=false


ALLOW_LOCAL_ONLY=false

SERVICE_CALL_TIMEOUT_MS=15000
RAJYA_VALIDATION_TIMEOUT_MS=8000
ENFORCEMENT_ACK_TIMEOUT_MS=10000


EVENT_STORE_URL=http://postgres-primary.staging:5432/sanskar_events
LINEAGE_PERSISTENCE_URL=http://postgres-primary.staging:5432/sanskar_lineage
CACHE_MODE=redis


GOVERNANCE_MODE=strict
CONSTITUTIONAL_BOUNDARY_CHECK=enabled
REPLAY_VERIFICATION=enabled
SCHEMA_VALIDATION_STRICT=true


READINESS_CHECK_DEPENDENCIES=rajya,enforcement,bucket,insightbridge
LIVENESS_CHECK_TIMEOUT_MS=3000


MAX_CONCURRENT_EXECUTIONS=500
QUEUE_MAX_SIZE=100000
BATCH_PROCESSING_ENABLED=true
BATCH_SIZE=200

TRACE_EXPORT_BACKEND=otlp
TRACE_BATCH_SIZE=500
TRACE_FLUSH_INTERVAL_MS=2000
