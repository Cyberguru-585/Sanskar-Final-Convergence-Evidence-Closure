
TANTRA_ENVIRONMENT=production
SERVICE_DISCOVERY_MODE=kubernetes
RAJYA_DISCOVERY_URL=http://rajya-service.tantra.svc.cluster.local:8080
ENFORCEMENT_DISCOVERY_URL=http://enforcement-service.tantra.svc.cluster.local:8080
BUCKET_DISCOVERY_URL=http://bucket-service.tantra.svc.cluster.local:8080
INSIGHTBRIDGE_DISCOVERY_URL=http://insightbridge-service.tantra.svc.cluster.local:8080

SANSKAR_PORT=8001
LOG_LEVEL=ERROR
ENABLE_DEBUG_ENDPOINTS=false


ALLOW_LOCAL_ONLY=false


SERVICE_CALL_TIMEOUT_MS=10000
RAJYA_VALIDATION_TIMEOUT_MS=6000
ENFORCEMENT_ACK_TIMEOUT_MS=8000
BUCKET_PERSISTENCE_TIMEOUT_MS=3000


EVENT_STORE_URL=postgresql://postgres-prod.tantra.svc.cluster.local/sanskar_events
LINEAGE_PERSISTENCE_URL=postgresql://postgres-prod.tantra.svc.cluster.local/sanskar_lineage
CACHE_MODE=redis


GOVERNANCE_MODE=strict
CONSTITUTIONAL_BOUNDARY_CHECK=enabled
REPLAY_VERIFICATION=enabled
SCHEMA_VALIDATION_STRICT=true


READINESS_CHECK_DEPENDENCIES=rajya,enforcement,bucket,insightbridge
LIVENESS_CHECK_TIMEOUT_MS=2000
HEALTH_CHECK_INTERVAL_MS=10000


MAX_CONCURRENT_EXECUTIONS=1000
QUEUE_MAX_SIZE=500000
BATCH_PROCESSING_ENABLED=true
BATCH_SIZE=500


TRACE_EXPORT_BACKEND=otlp
TRACE_BATCH_SIZE=1000
TRACE_FLUSH_INTERVAL_MS=1000


ENABLE_CIRCUIT_BREAKER=true
CIRCUIT_BREAKER_THRESHOLD=50
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=30000


AUDIT_LOG_ENABLED=true
AUDIT_LOG_DESTINATION=syslog://logging.tantra.svc.cluster.local
