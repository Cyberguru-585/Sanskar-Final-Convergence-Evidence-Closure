{
  "schema_name": "SANSKAR_OUTPUT_CONTRACT",
  "schema_version": "v1",
  "description": "Contract for Sanskar output to downstream participants (RAJYA, Bucket, InsightBridge)",
  
  "required_fields": [
    "trace_id",
    "entities",
    "ranking",
    "confidence",
    "decision_state"
  ],
  
  "field_definitions": {
    "trace_id": {
      "type": "string",
      "description": "Trace ID preserved from input (IMMUTABLE)",
      "pattern": "^TRACE-[a-f0-9]{12}$",
      "immutable": true,
      "propagation_rule": "MUST_PRESERVE",
      "regeneration": "NEVER"
    },
    "entities": {
      "type": "array",
      "description": "Scored and ranked entities",
      "items": {
        "type": "object",
        "required": ["entity_id", "score", "confidence"],
        "properties": {
          "entity_id": {"type": "string"},
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Computed ranking score"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Confidence in this entity's score"
          },
          "decision_state": {
            "type": "string",
            "enum": ["CONFIDENT", "AMBIGUOUS", "LOW_CONFIDENCE"]
          }
        }
      }
    },
    "ranking": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Ordered entity IDs from highest to lowest score"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Overall signal quality confidence"
    },
    "decision_state": {
      "type": "string",
      "enum": ["CONFIDENT", "AMBIGUOUS", "LOW_CONFIDENCE"],
      "description": "Indicates decision certainty"
    },
    "execution_hash": {
      "type": "string",
      "description": "SHA256 hash of input contract for replay verification",
      "pattern": "^[a-f0-9]{16}$"
    },
    "contract_version": {
      "type": "string",
      "enum": ["v1", "v1.1"],
      "default": "v1"
    }
  },
  
  "trace_continuity_rules": [
    {
      "rule": "trace_preservation",
      "description": "trace_id must be identical to input trace_id",
      "verification": "DOWNSTREAM can validate this"
    },
    {
      "rule": "no_trace_regeneration",
      "description": "Sanskar NEVER creates new trace_id",
      "violation": "CONSTITUTIONAL_BOUNDARY_VIOLATION"
    },
    {
      "rule": "execution_hash_for_replay",
      "description": "execution_hash enables replay verification",
      "verification": "Bucket stores hash for determinism check"
    }
  ],
  
  "boundary_declarations": [
    {
      "boundary": "confidence_not_legitimacy",
      "statement": "High confidence does NOT confer legitimacy",
      "implication": "RAJYA must independently validate"
    },
    {
      "boundary": "decision_state_flag",
      "statement": "AMBIGUOUS flag indicates score separation < 0.1",
      "implication": "Downstream must handle ambiguity"
    }
  ],
  
  "schema_compatibility": {
    "v1_to_v1_1_migration": "Backwards compatible - no breaking changes",
    "downgrade_path": "Not supported - v1.1 contracts not compatible with v1 consumers",
    "version_negotiation": "Participants must announce supported versions"
  },
  
  "failure_visibility": {
    "schema_mismatch": {
      "detection": "IMMEDIATE - schema validator fails",
      "visibility": "EXPLICIT - failure contract returned",
      "trace_preservation": "MANDATORY - failure includes trace_id"
    },
    "version_incompatibility": {
      "detection": "IMMEDIATE - version check fails",
      "visibility": "EXPLICIT - incompatibility error returned",
      "action": "REJECT - upstream rejects non-compliant output"
    }
  },
  
  "example_valid_contract": {
    "trace_id": "TRACE-a1b2c3d4e5f6",
    "entities": [
      {
        "entity_id": "REGION-1",
        "score": 0.95,
        "confidence": 0.92,
        "decision_state": "CONFIDENT"
      },
      {
        "entity_id": "REGION-2",
        "score": 0.87,
        "confidence": 0.88,
        "decision_state": "CONFIDENT"
      }
    ],
    "ranking": ["REGION-1", "REGION-2"],
    "confidence": 0.91,
    "decision_state": "CONFIDENT",
    "execution_hash": "a1b2c3d4e5f6g7h8",
    "contract_version": "v1"
  }
}
