{
  "schema_name": "INPUT_SIGNAL_CONTRACT",
  "schema_version": "v1",
  "description": "Contract for signal input from Signal Source to Sanskar",
  
  "required_fields": [
    "trace_id",
    "signal",
    "timestamp"
  ],
  
  "field_definitions": {
    "trace_id": {
      "type": "string",
      "description": "Unique trace identifier (format: TRACE-xxxxx)",
      "pattern": "^TRACE-[a-f0-9]{12}$",
      "immutable": true,
      "must_propagate": true,
      "example": "TRACE-a1b2c3d4e5f6"
    },
    "signal": {
      "type": "object",
      "description": "Signal data containing entities and ranking",
      "required_properties": ["entities", "ranking"],
      "properties": {
        "entities": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["entity_id", "score"],
            "properties": {
              "entity_id": {"type": "string"},
              "score": {"type": "number", "minimum": 0, "maximum": 1}
            }
          }
        },
        "ranking": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Ordered list of entity IDs by score"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Signal quality confidence metric"
        },
        "decision_state": {
          "type": "string",
          "enum": ["CONFIDENT", "AMBIGUOUS", "LOW_CONFIDENCE"],
          "description": "State of decision certainty"
        }
      }
    },
    "timestamp": {
      "type": "string",
      "format": "iso8601",
      "description": "ISO 8601 timestamp with Z suffix",
      "example": "2026-05-22T10:30:45.123456Z"
    },
    "contract_version": {
      "type": "string",
      "enum": ["v1", "v1.1"],
      "default": "v1",
      "description": "Version of this contract schema"
    }
  },
  
  "validation_rules": [
    {
      "rule": "trace_id_immutability",
      "description": "trace_id must NOT be regenerated during propagation",
      "enforcement": "MANDATORY"
    },
    {
      "rule": "timestamp_validity",
      "description": "timestamp must be valid ISO 8601 with Z suffix",
      "enforcement": "MANDATORY"
    },
    {
      "rule": "entity_score_valid_range",
      "description": "All entity scores must be between 0 and 1",
      "enforcement": "MANDATORY"
    },
    {
      "rule": "ranking_consistency",
      "description": "Ranking must contain all entity IDs from entities array",
      "enforcement": "MANDATORY"
    }
  ],
  
  "failure_cases": [
    {
      "case": "MISSING_TRACE_ID",
      "description": "Input contract does not include trace_id",
      "action": "REJECT",
      "response_code": "VALIDATION_FAILURE"
    },
    {
      "case": "INVALID_TRACE_ID_FORMAT",
      "description": "trace_id does not match TRACE-xxxxx pattern",
      "action": "REJECT",
      "response_code": "VALIDATION_FAILURE"
    },
    {
      "case": "INVALID_TIMESTAMP",
      "description": "timestamp is not valid ISO 8601",
      "action": "REJECT",
      "response_code": "VALIDATION_FAILURE"
    },
    {
      "case": "MISSING_REQUIRED_SIGNAL_FIELDS",
      "description": "signal object missing entities or ranking",
      "action": "REJECT",
      "response_code": "VALIDATION_FAILURE"
    }
  ],
  
  "example_valid_contract": {
    "trace_id": "TRACE-a1b2c3d4e5f6",
    "signal": {
      "entities": [
        {"entity_id": "REGION-1", "score": 0.95},
        {"entity_id": "REGION-2", "score": 0.87}
      ],
      "ranking": ["REGION-1", "REGION-2"],
      "confidence": 0.91,
      "decision_state": "CONFIDENT"
    },
    "timestamp": "2026-05-22T10:30:45.123456Z",
    "contract_version": "v1"
  }
}
